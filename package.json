{
  "name": "@company/ui",
  "version": "1.0.0",
  "description": "Shared UI components for Company applications.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs"
    },
    "./components/ui/button": {
      "types": "./dist/components/ui/button.d.mts",
      "import": "./dist/components/ui/button.mjs"
    },
    "./components/ui/*": {
      "types": "./dist/components/ui/*.d.mts",
      "import": "./dist/components/ui/*.mjs"
    },
    "./styles/theme.css": {
      "types": "./dist/styles/theme.css.d.ts",
      "style": "./dist/styles/theme.css",
      "default": "./dist/styles/theme.css"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "npm run build",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "radix-ui": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "fast-glob": "^3.3.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illarock/company-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
